      <aliases enabled='yes' />
      <column caption='Year Highlight' datatype='string' name='[Calculation_251638629479788544]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Year] &gt;= 2019 AND [Year] &lt;= 2024 THEN &quot;Disruption&quot;&#13;&#10;ELSEIF [Year] &lt;= 1994 THEN &quot;Pre-Trend&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Passenger T Diff ' datatype='integer' name='[Calculation_262334680962568192]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Year] = 2023 THEN [passengers] END)&#13;&#10;    - SUM(IF [Year] = 1993 THEN [passengers] END)' />
      </column>
      <column caption='Price AVG Diff' datatype='real' name='[Calculation_262334680967639041]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(IF [Year] = 2024 THEN [fare] END)&#13;&#10;    - AVG(IF [Year] = 1993 THEN [fare] END)' />
      </column>
      <column caption='Price Diff' datatype='real' name='[Calculation_262334680968122371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;    AVG(IF [Year] = 2024 THEN [fare] END)&#13;&#10;    - AVG(IF [Year] = 1993 THEN [fare] END)&#13;&#10;) &#13;&#10;/&#13;&#10;AVG(IF [Year] = 1993 THEN [fare] END)&#13;&#10;* 100' />
      </column>
      <column caption='Passengers Diff' datatype='real' name='[Calculation_799670410050371586]' role='measure' type='quantitative'>
